@baseUrl = http://localhost:7070
@authToken = paste-jwt-token-here

### Health check
GET {{baseUrl}}/health

### Route overview
GET {{baseUrl}}/routes

### Register user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "username": "student1",
  "password": "secret123"
}

###
### Login user
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "username": "student1",
  "password": "secret123"
}

### Current authenticated user
GET {{baseUrl}}/auth/me
Authorization: Bearer {{authToken}}

###
POST {{baseUrl}}/ai/elaborate
Content-Type: application/json

{
  "title": "Bananas are slightly radioactive",
  "body": "Bananas contain potassium-40, which makes them very slightly radioactive."
}

###
### Create content
POST {{baseUrl}}/content
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "title": "Did you know?",
  "body": "Honey never spoils.",
  "contentType": "FACT",
  "category": "Science",
  "source": "National Geographic",
  "author": "Unknown Author"
}

### Get all content
GET {{baseUrl}}/content

### Get content filtered by type
GET {{baseUrl}}/content?type=FACT

### Get only active content
GET {{baseUrl}}/content?activeOnly=true

### Get content by id
GET {{baseUrl}}/content/1

### Create or update interaction for content
POST {{baseUrl}}/content/1/interactions
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "reactionType": "BOOKMARK"
}

### Get interactions for content
GET {{baseUrl}}/content/1/interactions

### Update content (PUT)
PUT {{baseUrl}}/content/1
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "title": "Did you know? (updated)",
  "body": "Honey can stay edible for thousands of years.",
  "contentType": "FACT",
  "category": "Science",
  "source": "Smithsonian",
  "author": "Unknown Author"
}


### Delete content
DELETE {{baseUrl}}/content/1
Authorization: Bearer {{authToken}}
